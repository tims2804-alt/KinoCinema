<Page x:Class="KinoCinema.Pages.HallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KinoCinema.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HallPage">

    <Grid Background="#F5F5F5" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="← Назад" 
                    Click="Back_Click" 
                    Padding="10,5" 
                    Background="Transparent" 
                    BorderBrush="#CCC" 
                    Cursor="Hand"
                    Margin="0,0,20,0"/>
            <TextBlock x:Name="HallTitle" Text="Выбор мест" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#DDD" Height="20" Margin="50,0,50,30" CornerRadius="10">
            <TextBlock Text="ЭКРАН" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#666" FontSize="12" FontWeight="Bold"/>
        </Border>

        <ItemsControl x:Name="SeatsGrid" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="6"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ToggleButton Content="{Binding Number}" 
                                  Width="60" Height="60" Margin="8"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  IsEnabled="{Binding IsAvailable}"
                                  Checked="Seat_Checked" 
                                  Unchecked="Seat_Unchecked">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="#28A745"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="16"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="8" 
                                                    BorderBrush="White" BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Background" Value="#FFC107"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#DC3545"/>
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <TextBlock x:Name="TotalPriceText" Text="Итого: 0 руб." FontSize="18" VerticalAlignment="Center" Margin="0,0,20,0" FontWeight="Bold"/>
            <Button Content="Купить билеты" Click="ConfirmBooking_Click" Padding="20,10" Background="#007BFF" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Page>