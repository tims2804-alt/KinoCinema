<Page x:Class="KinoCinema.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KinoCinema.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <TextBlock Text="Авторизация" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин:"/>
            <TextBox x:Name="LoginField" Margin="0,5,0,15" Padding="5"/>

            <TextBlock Text="Пароль:"/>
            <PasswordBox x:Name="PasswordField" Margin="0,5,0,15" Padding="5"/>

            <Button Content="Войти" Click="Login_Click" Height="35" 
                Background="#007ACC" Foreground="White" FontWeight="Bold"/>

            <TextBlock Margin="0,15,0,0" HorizontalAlignment="Center">
            Нет аккаунта? <Hyperlink Click="GoToRegister_Click">Зарегистрироваться</Hyperlink>
            </TextBlock>

            <Button Content="Назад к фильмам" Click="Back_Click" Margin="0,20,0,0" 
                Background="Transparent" BorderBrush="Gray"/>
        </StackPanel>
    </Grid>
</Page>
