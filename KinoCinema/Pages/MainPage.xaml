<Page x:Class="KinoCinema.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KinoCinema.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" Padding="15" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="SearchBox" Width="250" Height="30" VerticalContentAlignment="Center" 
                         Padding="10,0" Margin="0,0,10,0" ToolTip="Поиск фильма..." 
                         TextChanged="SearchBox_TextChanged"/>

                <ComboBox x:Name="SortCombo" Width="150" Height="30" SelectedIndex="0" Margin="0,0,20,0" 
                          SelectionChanged="SortCombo_SelectionChanged">
                    <ComboBoxItem Content="По названию"/>
                    <ComboBoxItem Content="По рейтингу"/>
                </ComboBox>

                <Button Content="Личный кабинет" Click="Profile_Click" Padding="15,5" 
                        Background="#007BFF" Foreground="White" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <ListBox Grid.Row="1" x:Name="MoviesList" Background="Transparent" BorderThickness="0" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Button Click="MovieClick" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                        <Border Background="White" CornerRadius="10" Margin="15" Width="190" BorderBrush="#EEE" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.1" ShadowDepth="2"/>
                            </Border.Effect>

                            <StackPanel>
                                <Grid>
                                    <Border CornerRadius="10,10,0,0" ClipToBounds="True">
                                        <Image Source="{Binding ImagePath}" Height="270" Stretch="UniformToFill"/>
                                    </Border>
                                    <Border Background="#CC000000" CornerRadius="5" HorizontalAlignment="Right" 
                                            VerticalAlignment="Top" Margin="8" Padding="6,3">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⭐ " Foreground="Gold" FontSize="12"/>
                                            <TextBlock Text="{Binding Rating}" Foreground="White" 
                                                       FontWeight="Bold" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" 
                                           Margin="10,10,10,5" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                                <TextBlock Text="Подробнее" Foreground="#007BFF" FontSize="12" 
                                           Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
                                    