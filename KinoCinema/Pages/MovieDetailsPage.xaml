<Page x:Class="KinoCinema.Pages.MovieDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KinoCinema.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MovieDetailsPage">

    <Grid Background="#F5F5F5" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" CornerRadius="10" Background="White">
            <Image x:Name="MovieImage" 
           Stretch="Uniform" 
           MaxHeight="450"/>
        </Border>
        
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="20,0,0,0">
            <TextBlock x:Name="MovieTitle" FontSize="32" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,10"/>
            <TextBlock x:Name="MovieGenre" FontSize="18" Foreground="Gray" Margin="0,0,0,20"/>

            <TextBlock Text="Описание:" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBlock x:Name="MovieDescription" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,30"/>

            <TextBlock Text="Расписание сеансов:" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl x:Name="SessionsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Time}" Click="Session_Click" Margin="0,0,10,10" 
        Padding="15,8" Background="#007ACC" Foreground="White">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <Button Content="← Назад к списку" Grid.Row="0" HorizontalAlignment="Left" 
            Click="Back_Click" Margin="0,0,0,20" Background="Transparent" BorderBrush="Gray"/>
    </Grid>
</Page>
