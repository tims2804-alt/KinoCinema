<Page x:Class="KinoCinema.Pages.OrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оформление билета">

    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
            <TextBlock Text="ПОДТВЕРЖДЕНИЕ ЗАКАЗА" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="#333"/>

            <Border Background="White" CornerRadius="10" Padding="20" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="TxtMovie" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtSession" FontSize="16" Foreground="Gray" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtSeats" FontSize="16" Margin="0,0,0,15" TextWrapping="Wrap"/>

                    <Separator Background="#EEE" Margin="0,10"/>

                    <DockPanel>
                        <TextBlock Text="ИТОГО К ОПЛАТЕ:" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtTotal" Text="0 руб." FontSize="22" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Right"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <UniformGrid Columns="2" Margin="0,30,0,0">
                <Button Content="Отмена" Click="Cancel_Click" Height="45" Margin="5" Background="White" BorderBrush="#CCC"/>
                <Button Content="Подтвердить покупку" Click="Confirm_Click" Height="45" Margin="5" Background="#28A745" Foreground="White" FontWeight="Bold"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Page>